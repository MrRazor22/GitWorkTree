<platform:DialogWindow  x:Class="GitWorkTree.View.WorkTreeDialogWindow"
                        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                        xmlns:platform="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
                        xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
                        xmlns:viewmodel="clr-namespace:GitWorkTree.ViewModel"
                        xmlns:usercontrols="clr-namespace:GitWorkTree.View.UserControls"
                        xmlns:converters="clr-namespace:GitWorkTree.View.Converters" 
                        toolkit:Themes.UseVsTheme="True"
                        mc:Ignorable="d"
                        Title="{Binding WindowTitle}"
                          Width="650"
                          MinHeight="250"
                          SizeToContent="Height"
                          FontSize="15"
                          FontWeight="DemiBold"
                          WindowStyle="SingleBorderWindow"
                          ResizeMode="NoResize">
    <Window.DataContext>
        <viewmodel:WorkTreeDialogViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:CommandTypeToBranchWorktreeLableConverter x:Key="CommandTypeToBranchWorktreeLableConverter"/>
        <converters:CommandTypeToForceCheckBoxTextConverter x:Key="CommandTypeToForceCheckBoxTextConverter"/>
        <converters:CommandTypeToCreateRemoveButtonTextConverter x:Key="CommandTypeToCreateRemoveButtonTextConverter"/>
        <converters:CreateCommandTypeVisibilityConverter x:Key="CreateCommandTypeVisibilityConverter"/>
        <converters:ManageCommandTypeVisibilityConverter x:Key="ManageCommandTypeVisibilityConverter"/>

        <ControlTemplate x:Key="ErrorTemplate">
            <Border BorderBrush="Red" BorderThickness="1">
                <AdornedElementPlaceholder x:Name="placeholder"/>
            </Border>
        </ControlTemplate>

        <Style TargetType="usercontrols:FolderEntry">
            <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ErrorTemplate}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="true">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={x:Static RelativeSource.Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid Grid.Row="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
                <RowDefinition Height="Auto"></RowDefinition>
            </Grid.RowDefinitions>


            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20*"></ColumnDefinition>
                    <ColumnDefinition Width="80*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <TextBlock FontWeight="SemiBold" Text="Repository: " d:Background="White" Grid.Row="0" Grid.Column="0" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left">
                </TextBlock>
                <TextBlock  Padding="5" d:Background="White" Grid.Row="0" Grid.Column="1" FontSize="14" TextWrapping="Wrap"
                            VerticalAlignment="Center" HorizontalAlignment="Stretch">
                    <Hyperlink NavigateUri="{Binding ActiveRepositoryPath, UpdateSourceTrigger=PropertyChanged}" RequestNavigate="Hyperlink_RequestNavigate">
                        <Run Text="{Binding ActiveRepositoryPath, UpdateSourceTrigger=PropertyChanged}" d:Text="D:/RepoPath" />
                    </Hyperlink>
                </TextBlock>
            </Grid>


            <Grid Grid.Row="1" Margin="0,0,0,12">
                <!-- If commandType is Manage, we show standard layout. If commandType is Create, we show the radio buttons. -->
                <Grid Visibility="{Binding CommandType, Converter={StaticResource ManageCommandTypeVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"></RowDefinition>
                        <RowDefinition Height="Auto"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="25*"></ColumnDefinition>
                        <ColumnDefinition Width="75*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <!-- Row 0: New Branch Selection -->
                    <RadioButton Grid.Row="0" Grid.Column="0" GroupName="BranchMode" IsChecked="{Binding IsNewBranchMode}" Content="New Branch:" VerticalAlignment="Center" FontSize="14" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,2,0,10" VerticalAlignment="Center">
                        <TextBox x:Name="NewBranchTextBox" Margin="0" Padding="4" FontSize="14" IsEnabled="{Binding IsNewBranchMode}" Text="{Binding NewBranchName, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" Validation.ErrorTemplate="{StaticResource ErrorTemplate}"/>
                        <StackPanel Orientation="Horizontal" Margin="2,4,0,2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=NewBranchTextBox, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="12" Height="12" Fill="Red" Data="M6,0 C2.68,0 0,2.68 0,6 C0,9.32 2.68,12 6,12 C9.32,12 12,9.32 12,6 C12,2.68 9.32,0 6,0 Z M6.5,9 H5.5 V8 H6.5 V9 Z M6.5,7 H5.5 V3 H6.5 V7 Z" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ElementName=NewBranchTextBox, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" VerticalAlignment="Center" FontWeight="Normal"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Row 1: Existing Branch Selection -->
                    <RadioButton Grid.Row="1" Grid.Column="0" GroupName="BranchMode" IsChecked="{Binding IsExistingBranchMode}" Content="Base Branch:" VerticalAlignment="Center" FontSize="14"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,2,0,2" VerticalAlignment="Center">
                        <ComboBox Name="BranchName" IsEditable="True" PreviewKeyDown="BranchName_PreviewKeyDown"
                                  ItemsSource="{Binding Branches_Worktrees}" SelectedItem="{Binding SelectedBranch_Worktree, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                                  Padding="5" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Stretch"      
                                  VirtualizingPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True" ScrollViewer.IsDeferredScrollingEnabled="True"
                                  Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                                  Validation.ValidationAdornerSiteFor="{Binding RelativeSource={RelativeSource Self}}">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Margin="2,4,0,2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=BranchName, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="12" Height="12" Fill="Red" Data="M6,0 C2.68,0 0,2.68 0,6 C0,9.32 2.68,12 6,12 C9.32,12 12,9.32 12,6 C12,2.68 9.32,0 6,0 Z M6.5,9 H5.5 V8 H6.5 V9 Z M6.5,7 H5.5 V3 H6.5 V7 Z" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ElementName=BranchName, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" VerticalAlignment="Center" FontWeight="Normal"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding CommandType, Converter={StaticResource CreateCommandTypeVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*"></ColumnDefinition>
                        <ColumnDefinition Width="80*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="{Binding CommandType, Converter={StaticResource CommandTypeToBranchWorktreeLableConverter}}" 
                           Grid.Column="0" FontSize="14"  VerticalAlignment="Center" HorizontalAlignment="Left">
                    </TextBlock>
                    <StackPanel Grid.Column="1" Margin="0,2,0,2" VerticalAlignment="Center">
                        <ComboBox Name="BranchNameManage" IsEditable="True" PreviewKeyDown="BranchName_PreviewKeyDown"
                              ItemsSource="{Binding Branches_Worktrees}" SelectedItem="{Binding SelectedBranch_Worktree, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                              Padding="5" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Stretch"      
                              VirtualizingPanel.IsVirtualizing="True" ScrollViewer.CanContentScroll="True" ScrollViewer.IsDeferredScrollingEnabled="True"
                              Validation.ErrorTemplate="{StaticResource ErrorTemplate}"
                              Validation.ValidationAdornerSiteFor="{Binding RelativeSource={RelativeSource Self}}">
                            <ComboBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ComboBox.ItemsPanel>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Margin="2,4,0,2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=BranchNameManage, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="12" Height="12" Fill="Red" Data="M6,0 C2.68,0 0,2.68 0,6 C0,9.32 2.68,12 6,12 C9.32,12 12,9.32 12,6 C12,2.68 9.32,0 6,0 Z M6.5,9 H5.5 V8 H6.5 V9 Z M6.5,7 H5.5 V3 H6.5 V7 Z" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ElementName=BranchNameManage, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" VerticalAlignment="Center" FontWeight="Normal"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Grid>


            <Grid Grid.Row="2" >
                <Grid d:Visibility="Collapsed"
                Visibility="{Binding CommandType, Converter={StaticResource ManageCommandTypeVisibilityConverter}}" Height="auto" Width="auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20*"></ColumnDefinition>
                        <ColumnDefinition Width="80*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <TextBlock d:Visibility="Visible"
                        FontWeight="SemiBold" Name="Path" Text="Path:"  
                       Grid.Column="0" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Left" >
                    </TextBlock>
                    <StackPanel Grid.Column="1" Margin="0,2,0,2" VerticalAlignment="Center">
                        <usercontrols:FolderEntry x:Name="folderEntry" d:Visibility="Visible"
                            FolderPath="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}" 
                            Description="Folder for branch worktree"
                            Validation.ErrorTemplate="{StaticResource ErrorTemplate}" />
                        <StackPanel Orientation="Horizontal" Margin="2,4,0,2">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=folderEntry, Path=(Validation.HasError)}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Path Width="12" Height="12" Fill="Red" Data="M6,0 C2.68,0 0,2.68 0,6 C0,9.32 2.68,12 6,12 C9.32,12 12,9.32 12,6 C12,2.68 9.32,0 6,0 Z M6.5,9 H5.5 V8 H6.5 V9 Z M6.5,7 H5.5 V3 H6.5 V7 Z" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ElementName=folderEntry, Path=(Validation.Errors)[0].ErrorContent}" Foreground="Red" FontSize="11" VerticalAlignment="Center" FontWeight="Normal"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Grid d:Visibility="Visible"
                    Visibility="{Binding CommandType, Converter={StaticResource CreateCommandTypeVisibilityConverter}}" Height="auto" Width="auto">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="1" Margin="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding OpenCommand}" CommandParameter="{Binding PreferredOpenAction}" FontSize="14" FontWeight="SemiBold" Padding="12,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ContentControl Content="{Binding PreferredOpenAction}" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PreferredOpenAction}" Value="CurrentWindow">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,2 h12 v12 H2 Z M3,5 h10 v8 H3 Z" Fill="#007ACC" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PreferredOpenAction}" Value="NewVSWindow">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,6 h10 v8 H2 Z M5,2 h12 v8 H15 V4 H5 Z" Fill="#007ACC" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PreferredOpenAction}" Value="DoNotOpen">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,6 h10 v8 H2 Z M5,2 h12 v8 H15 V4 H5 Z" Fill="#007ACC" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PreferredOpenAction}" Value="Explorer">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,2 h4 l1.5,1.5 h6.5 v8.5 H2 Z" Fill="#EAA200" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Text="Open" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="ButtonOpen_Click" Width="20" Padding="0">
                            <Path Data="M 0 0 L 3 3 L 6 0" Stroke="Black" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Current Window" Command="{Binding OpenCommand}" CommandParameter="CurrentWindow">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M2,2 h12 v12 H2 Z M3,5 h10 v8 H3 Z" Fill="#007ACC" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Open in New Window" Command="{Binding OpenCommand}" CommandParameter="NewVSWindow">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M2,6 h10 v8 H2 Z M5,2 h12 v8 H15 V4 H5 Z" Fill="#007ACC" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Open in Explorer" Command="{Binding OpenCommand}" CommandParameter="Explorer">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M2,2 h4 l1.5,1.5 h6.5 v8.5 H2 Z" Fill="#EAA200" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>
                </Grid>

            </Grid>

            <Grid Grid.Row="3" Margin="7">
                <CheckBox x:Name="ForceCreateRemove" IsChecked="{Binding IsForceCreateRemove}" FontSize="14"
                      Content="{Binding CommandType, Converter={StaticResource CommandTypeToForceCheckBoxTextConverter}}"
                      VerticalAlignment="Center" HorizontalAlignment="Left" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="Prune" Command="{Binding PruneCommand}" Content="Prune" Margin="0,0,7,0"
                            Visibility="{Binding CommandType, Converter={StaticResource CreateCommandTypeVisibilityConverter}}"
                            FontSize="14" FontWeight="SemiBold" Padding="12,5" />

                    <!-- Create Split Button (Visible in Create mode / ManageCommandTypeVisibilityConverter) -->
                    <Grid Visibility="{Binding CommandType, Converter={StaticResource ManageCommandTypeVisibilityConverter}}" Margin="0,0,7,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Command="{Binding CreateCommand}" CommandParameter="{Binding PreferredCreateAction}" 
                                FontSize="14" FontWeight="SemiBold" Padding="12,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <ContentControl Content="{Binding PreferredCreateAction}" Margin="0,0,6,0" VerticalAlignment="Center">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PreferredCreateAction}" Value="DoNotOpen">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M8,2 v12 M2,8 h12" Stroke="#565656" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PreferredCreateAction}" Value="CurrentWindow">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,2 h12 v12 H2 Z M3,5 h10 v8 H3 Z" Fill="#007ACC" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PreferredCreateAction}" Value="NewVSWindow">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate>
                                                                <Viewbox Width="14" Height="14">
                                                                    <Path Data="M2,6 h10 v8 H2 Z M5,2 h12 v8 H15 V4 H5 Z" Fill="#007ACC" />
                                                                </Viewbox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                                <TextBlock Text="Create" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1" Click="ButtonCreate_Click" Width="20" Padding="0">
                            <Path Data="M 0 0 L 3 3 L 6 0" Stroke="Black" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Create Only" Command="{Binding CreateCommand}" CommandParameter="DoNotOpen">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M8,2 v12 M2,8 h12" Stroke="#565656" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Create and Open in Current Window" Command="{Binding CreateCommand}" CommandParameter="CurrentWindow">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M2,2 h12 v12 H2 Z M3,5 h10 v8 H3 Z" Fill="#007ACC" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Create and Open in New Window" Command="{Binding CreateCommand}" CommandParameter="NewVSWindow">
                                        <MenuItem.Icon>
                                            <Viewbox Width="16" Height="16">
                                                <Path Data="M2,6 h10 v8 H2 Z M5,2 h12 v8 H15 V4 H5 Z" Fill="#007ACC" />
                                            </Viewbox>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </Grid>

                    <!-- Remove Button (Visible in Manage mode / CreateCommandTypeVisibilityConverter) -->
                    <Button Content="Remove" Command="{Binding RemoveCommand}" Margin="0,0,7,0"
                            Visibility="{Binding CommandType, Converter={StaticResource CreateCommandTypeVisibilityConverter}}"
                            FontSize="14" FontWeight="SemiBold" Padding="12,5"
                            Name="buttonRemove" />

                    <Button Content="Cancel" FontSize="14" FontWeight="SemiBold" Padding="12,5"
                            Command="{Binding CancelCommand}" Name="button3" />
                </StackPanel>
            </Grid>

        </Grid>

    </Grid>
</platform:DialogWindow>
