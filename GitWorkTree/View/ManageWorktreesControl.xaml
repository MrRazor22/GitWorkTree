<UserControl x:Class="GitWorkTree.View.ManageWorktreesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:viewmodel="clr-namespace:GitWorkTree.ViewModel"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:platformUI="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             xmlns:catalog="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.ImageCatalog"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">
    <UserControl.DataContext>
        <viewmodel:ManageWorktreesViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- VS Font/Color style for primary list/tree text -->
        <Style x:Key="PrimaryTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- VS Font/Color style for subdued/secondary text -->
        <Style x:Key="SubduedTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- VS Style for GridViewColumnHeader -->
        <Style x:Key="VsGridViewColumnHeaderStyle" TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"/>
            <Setter Property="FontSize" Value="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridViewColumnHeader">
                        <Grid SnapsToDevicePixels="true">
                            <Border BorderThickness="{TemplateBinding BorderThickness}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    Background="{TemplateBinding Background}" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                  RecognizesAccessKey="True" 
                                                  SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                            <Thumb x:Name="PART_HeaderGripper" HorizontalAlignment="Right" Width="8" Margin="0,0,-4,0" Cursor="SizeWE">
                                <Thumb.Template>
                                    <ControlTemplate TargetType="{x:Type Thumb}">
                                        <Border Background="Transparent" Width="{TemplateBinding Width}"/>
                                    </ControlTemplate>
                                </Thumb.Template>
                            </Thumb>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Style to match VS search/filter textboxes -->
        <Style x:Key="VsSearchTextBox" TargetType="TextBox">
            <Setter Property="Padding" Value="24,3,4,3"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"/>
            <Setter Property="CaretBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="border" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    Background="{TemplateBinding Background}" 
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Search Icon (Magnifying Glass) on the left -->
                            <Path x:Name="SearchIcon" 
                                  Data="M 5.5 1.5 A 4 4 0 1 1 1.5 5.5 A 4 4 0 0 1 5.5 1.5 M 8.3 8.3 L 11.5 11.5" 
                                  Stroke="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" 
                                  StrokeThickness="1.5" 
                                  Width="12" Height="12" 
                                  HorizontalAlignment="Left" 
                                  VerticalAlignment="Center" 
                                  Margin="6,0,0,0"
                                  IsHitTestVisible="False"/>
                            <!-- Watermark / Placeholder Text -->
                            <TextBlock x:Name="Watermark" 
                                       Text="Search worktrees" 
                                       FontStyle="Italic" 
                                       Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" 
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Center" 
                                       Margin="26,0,0,0" 
                                       IsHitTestVisible="False" 
                                       Visibility="Collapsed"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style to match VS CommandBar/ToolBar Button -->
        <Style x:Key="VsToolbarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="true" CornerRadius="2">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" HorizontalAlignment="Center" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="true">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseDownBackgroundGradientKey}}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarBorderKey}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="false">
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Shared TreeViewItem Style for full-width theme-aware highlighting -->
        <Style x:Key="VsTreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Bd Border spans the full width of the parent (stretching) -->
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True" TextElement.Foreground="{TemplateBinding Foreground}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="16"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <ToggleButton x:Name="Expander" ClickMode="Press" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Focusable" Value="False"/>
                                                <Setter Property="Width" Value="12"/>
                                                <Setter Property="Height" Value="12"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Width="12" Height="12" Background="Transparent">
                                                                <Path x:Name="ExpandPath" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" Data="M2,1 L2,9 L8,5 Z"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="ExpandPath" Property="RenderTransform">
                                                                        <Setter.Value>
                                                                            <RotateTransform Angle="45" CenterX="5" CenterY="5"/>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <ContentPresenter Grid.Column="1" x:Name="PART_Header" ContentSource="Header" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                </Grid>
                            </Border>
                            <ItemsPresenter Grid.Row="1" x:Name="ItemsHost" Margin="16,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemActiveBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemActiveTextBrushKey}}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemInactiveBrushKey}}"/>
                                <Setter Property="Foreground" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemInactiveTextBrushKey}}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- VS-style Expander Template -->
        <Style x:Key="VsExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="true">
                            <DockPanel>
                                <!-- Header Button -->
                                <ToggleButton x:Name="HeaderSite" DockPanel.Dock="Top" 
                                              MinHeight="23" 
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                                              BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"
                                              BorderThickness="0,0,0,1"
                                              Content="{TemplateBinding Header}"
                                              ContentTemplate="{TemplateBinding HeaderTemplate}"
                                              ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
                                              HorizontalContentAlignment="Stretch"
                                              VerticalContentAlignment="Center">
                                    <ToggleButton.Style>
                                        <Style TargetType="ToggleButton">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="4,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="20"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <!-- Chevron -->
                                                                <Path x:Name="Chevron" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                                      Stroke="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" 
                                                                      StrokeThickness="1.5"
                                                                      Fill="Transparent"
                                                                      Data="M 3 1 L 6.5 4.5 L 3 8" Width="10" Height="8" Stretch="Uniform"/>
                                                                
                                                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center" 
                                                                                  Content="{TemplateBinding Content}" 
                                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"/>
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Chevron" Property="Data" Value="M 1 3 L 4.5 6.5 L 8 3"/>
                                                            </Trigger>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ToggleButton.Style>
                                </ToggleButton>
                                
                                <!-- Content Site -->
                                <ContentPresenter x:Name="ExpandSite" DockPanel.Dock="Bottom" 
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                  Visibility="Collapsed" 
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}" 
                                                  Focusable="false"/>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="true">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
        <Grid.RowDefinitions>
            <!-- Toolbar and Active Repository Info -->
            <RowDefinition Height="Auto"/>
            <!-- Content Split Pane -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar mimicking "Manage Branches" -->
        <Border Grid.Row="0" BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}" BorderThickness="0,0,0,1" Padding="4">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentState}" Value="WarmingUp">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentState}" Value="NoRepository">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Button Style="{StaticResource VsToolbarButton}" Command="{Binding CreateCommand}" ToolTip="Create a new worktree and optional branch" Width="22" Height="22" Padding="3">
                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Add}" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource VsToolbarButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh the worktree list and details" Width="22" Height="22" Padding="3">
                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Refresh}" Width="16" Height="16"/>
                    </Button>
                    <Button Style="{StaticResource VsToolbarButton}" Command="{Binding PruneCommand}" ToolTip="Prune Worktrees: Clean up reference information for worktree folders that have been manually deleted from disk" Width="22" Height="22" Padding="3">
                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.DeleteFolder}" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <!-- Repository link header similar to Visual Studio's layout, docked to the right -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                    <TextBlock Text="Repository:" FontWeight="Bold" FontSize="11" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock TextWrapping="NoWrap" FontSize="11" VerticalAlignment="Center">
                        <Hyperlink Command="{Binding ExplorePathCommand}" CommandParameter="{Binding ActiveRepositoryPath}" TextDecorations="None">
                            <Hyperlink.Style>
                                <Style TargetType="Hyperlink" BasedOn="{StaticResource {x:Type Hyperlink}}">
                                    <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextKey}}"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextHoverKey}}"/>
                                            <Setter Property="TextDecorations" Value="Underline"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Hyperlink.Style>
                            <Run Text="{Binding ActiveRepositoryPath}"/>
                        </Hyperlink>
                    </TextBlock>
                    <Button Command="{Binding CopyRepositoryPathCommand}" ToolTip="Copy Repository Path to Clipboard" Margin="6,0,0,0" Padding="1" Background="Transparent" BorderThickness="0" Width="16" Height="16" VerticalAlignment="Center" Style="{StaticResource VsToolbarButton}">
                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Copy}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WarmingUp State Panel -->
        <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentState}" Value="WarmingUp">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Loading repository..." FontSize="13" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <ProgressBar Width="200" Height="4" IsIndeterminate="True" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
            </StackPanel>
        </Grid>

        <!-- NoRepository State Panel -->
        <Grid Grid.Row="1" Margin="40" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentState}" Value="NoRepository">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                <Viewbox Width="48" Height="48" Margin="0,0,0,16" HorizontalAlignment="Center">
                    <Path Data="M24,2A22,22,0,1,0,46,24,22,22,0,0,0,24,2Zm1,31.75V27.1a3.63,3.63,0,0,1,0-6.2v-6.6a2,2,0,1,1,2,0v6.6a3.63,3.63,0,0,1,0,6.2v6.4a2,2,0,1,1,-2,.25Z" Fill="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                </Viewbox>
                <TextBlock Text="No Git Repository" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" HorizontalAlignment="Center"/>
                <TextBlock Text="Open a solution that is part of a Git repository to manage worktrees." FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Active States: Split Layout Panel -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding CurrentState}" Value="LoadingWorktrees">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentState}" Value="NoSelection">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding CurrentState}" Value="WorktreeSelected">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <!-- Left Pane (Search and tree) -->
                <ColumnDefinition Width="280" MinWidth="150"/>
                <!-- Splitter -->
                <ColumnDefinition Width="5"/>
                <!-- Right Pane (Detail view) -->
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Loading Indicator -->
            <ProgressBar Height="2" IsIndeterminate="True" VerticalAlignment="Top" Panel.ZIndex="999"
                         Visibility="{Binding IsAnyLoading, Converter={StaticResource BoolToVis}}"
                         Background="Transparent" BorderThickness="0" 
                         Foreground="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>

            <!-- Left Pane -->
            <Grid Grid.Column="0" Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Style="{StaticResource VsSearchTextBox}" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                <!-- Hierarchical TreeView mimicking Manage Branches -->
                <TreeView Grid.Row="1" ItemsSource="{Binding WorktreeHierarchy}" SelectedItemChanged="TreeView_SelectedItemChanged"
                          Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                          Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                          ScrollViewer.CanContentScroll="True">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource VsTreeViewItemStyle}">
                            <Setter Property="IsExpanded" Value="True"/>
                            <EventSetter Event="PreviewMouseLeftButtonDown" Handler="TreeViewItem_PreviewMouseLeftButtonDown"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <!-- Directory / Folder node representation -->
                        <HierarchicalDataTemplate DataType="{x:Type viewmodel:HierarchyNode}" ItemsSource="{Binding Items}">
                            <Grid HorizontalAlignment="Stretch" Margin="2,0">
                                <!-- Folder representation -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding WorktreeItem}">
                                                    <DataTrigger.Value>
                                                        <x:Null/>
                                                    </DataTrigger.Value>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    
                                    <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.FolderClosed}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Normal" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                                
                                <!-- Leaf Worktree Item representation -->
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFolder}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
   
                                    <!-- Bullet indicator for Dirty worktree -->
                                    <Ellipse Grid.Column="0" Width="6" Height="6" Fill="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}" Margin="0,0,6,0" VerticalAlignment="Center" Visibility="{Binding WorktreeItem.IsDirty, Converter={StaticResource BoolToVis}}" ToolTip="Has uncommitted changes"/>
   
                                    <!-- Branch Icon -->
                                    <imaging:CrispImage Grid.Column="1" Moniker="{x:Static catalog:KnownMonikers.Branch}" Width="16" Height="16" Margin="0,0,6,0" VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="2" Text="{Binding WorktreeItem.FolderName}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12"/>
   
                                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                                        <!-- Current Badge -->
                                        <Border CornerRadius="10" BorderThickness="1" 
                                                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}" 
                                                Background="{DynamicResource {x:Static vsshell:VsBrushes.HighlightKey}}" 
                                                Padding="5,1" Margin="2,0"
                                                Visibility="{Binding WorktreeItem.IsCurrent, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="current" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.HighlightTextKey}}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                        <!-- Main Badge -->
                                        <Border CornerRadius="10" BorderThickness="1" 
                                                BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}" 
                                                Background="Transparent" 
                                                Padding="5,1" Margin="2,0"
                                                Visibility="{Binding WorktreeItem.IsMain, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="main" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
 
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"/>
 
            <!-- Right Pane: Details & Interactive Actions -->
            <Grid Grid.Column="2" Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}">
                <!-- Details view -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="WorktreeSelected">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <!-- Details headers -->
                        <RowDefinition Height="Auto"/>
                        <!-- Split sections (Changes & Outgoing) -->
                        <RowDefinition Height="*"/>
                        <!-- Action buttons -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
 
                    <!-- Row 0: Worktree Header details -->
                    <StackPanel Grid.Row="0" Margin="12,12,12,6">
                        <TextBlock Text="{Binding SelectedWorktree.FolderName}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" Margin="0,0,0,8"/>
                        
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Branch:" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                            <TextBlock Grid.Column="1" Text="{Binding DetailBranchName}" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Status:" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Total Changes -->
                                <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Edit}" Width="12" Height="12" Margin="0,0,4,0" ToolTip="Uncommitted Changes"/>
                                <TextBlock Text="{Binding Changes.Count}" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" Margin="0,0,2,0" FontWeight="SemiBold"/>
                                <TextBlock Text=" changes" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" Margin="0,0,16,0"/>

                                <!-- Separator -->
                                <TextBlock Text="|" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" Margin="0,0,16,0" FontSize="12"/>

                                <!-- Ahead (Outgoing) -->
                                <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Upload}" Width="12" Height="12" Margin="0,0,4,0" ToolTip="Outgoing Commits (Ahead)"/>
                                <TextBlock Text="{Binding AheadCount}" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" Margin="0,0,2,0" FontWeight="SemiBold"/>
                                <TextBlock Text=" ahead" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}" Margin="0,0,16,0"/>

                                <!-- Behind (Incoming) -->
                                <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Download}" Width="12" Height="12" Margin="0,0,4,0" ToolTip="Incoming Commits (Behind)"/>
                                <TextBlock Text="{Binding BehindCount}" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" Margin="0,0,2,0" FontWeight="SemiBold"/>
                                <TextBlock Text=" behind" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Path:" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock TextWrapping="Wrap" FontSize="11" VerticalAlignment="Center">
                                    <Hyperlink Command="{Binding ExplorePathCommand}" CommandParameter="{Binding DetailPath}" TextDecorations="None">
                                        <Hyperlink.Style>
                                            <Style TargetType="Hyperlink" BasedOn="{StaticResource {x:Type Hyperlink}}">
                                                <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextKey}}"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ControlLinkTextHoverKey}}"/>
                                                        <Setter Property="TextDecorations" Value="Underline"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Hyperlink.Style>
                                        <Run Text="{Binding DetailPath}"/>
                                    </Hyperlink>
                                </TextBlock>
                                <Button Command="{Binding CopyPathCommand}" ToolTip="Copy Path to Clipboard" Margin="6,0,0,0" Padding="1" Background="Transparent" BorderThickness="0" Width="16" Height="16" VerticalAlignment="Center" Style="{StaticResource VsToolbarButton}">
                                    <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Copy}" Width="14" Height="14"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                        
                        <Separator Margin="0,10,0,4" Background="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}"/>
                    </StackPanel>
 
                    <!-- Row 1: Collapsible panel for Changes and Outgoing lists -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="12,0,12,6">
                        <StackPanel>
                            <!-- Staged Changes List -->
                            <Expander IsExpanded="True" Margin="0,0,0,6" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">
                                <Expander.Header>
                                    <TextBlock Text="{Binding StagedCount, StringFormat='Staged Changes ({0})'}" 
                                               FontFamily="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"
                                               FontSize="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                </Expander.Header>
                                <Expander.Style>
                                    <Style TargetType="Expander" BasedOn="{StaticResource VsExpanderStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StagedCount}" Value="0">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Expander.Style>
                                <TreeView Name="StagedChangesTreeView" ItemsSource="{Binding StagedChangesTree}" MouseDoubleClick="ChangesTreeView_MouseDoubleClick"
                                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                          ScrollViewer.CanContentScroll="True">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource VsTreeViewItemStyle}">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type viewmodel:GitChangeNode}" ItemsSource="{Binding Children}">
                                            <Grid x:Name="RowGrid" Margin="2,0" HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,6,0">
                                                    <!-- Folder Icon -->
                                                    <imaging:CrispImage x:Name="FolderIcon" Moniker="{x:Static catalog:KnownMonikers.FolderClosed}" Width="14" Height="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                    <!-- File Icon -->
                                                    <imaging:CrispImage x:Name="FileIcon" Moniker="{x:Static catalog:KnownMonikers.TextFile}" Width="14" Height="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="11" Style="{StaticResource PrimaryTextBlockStyle}"/>

                                                <!-- Status Text (far right) -->
                                                <TextBlock Grid.Column="2" x:Name="StatusText" Text="{Binding Status}" Margin="12,0,4,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Grid>

                                            <HierarchicalDataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                    <Setter TargetName="FolderIcon" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFile}" Value="True">
                                                    <Setter TargetName="FileIcon" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="StatusText" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>

                                                <!-- Colors and ToolTips for status -->
                                                <DataTrigger Binding="{Binding Status}" Value="M">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#D29A2E"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Modified"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="A">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#57B05C"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Added"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="D">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#E05B5B"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Deleted"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="??">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="Gray"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Untracked"/>
                                                </DataTrigger>
                                            </HierarchicalDataTemplate.Triggers>
                                        </HierarchicalDataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </Expander>

                            <!-- Unstaged Changes List -->
                            <Expander Style="{StaticResource VsExpanderStyle}" IsExpanded="True" Margin="0,0,0,6" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">
                                <Expander.Header>
                                    <TextBlock Text="{Binding ChangesCount, StringFormat='Changes ({0})'}" 
                                               FontFamily="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"
                                               FontSize="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                </Expander.Header>
                                <TreeView Name="UnstagedChangesTreeView" ItemsSource="{Binding UnstagedChangesTree}" MouseDoubleClick="ChangesTreeView_MouseDoubleClick"
                                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                                          ScrollViewer.CanContentScroll="True">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource VsTreeViewItemStyle}">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type viewmodel:GitChangeNode}" ItemsSource="{Binding Children}">
                                            <Grid x:Name="RowGrid" Margin="2,0" HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,6,0">
                                                    <!-- Folder Icon -->
                                                    <imaging:CrispImage x:Name="FolderIcon" Moniker="{x:Static catalog:KnownMonikers.FolderClosed}" Width="14" Height="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                    <!-- File Icon -->
                                                    <imaging:CrispImage x:Name="FileIcon" Moniker="{x:Static catalog:KnownMonikers.TextFile}" Width="14" Height="14" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                </StackPanel>

                                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" FontSize="11" Style="{StaticResource PrimaryTextBlockStyle}"/>

                                                <!-- Status Text (far right) -->
                                                <TextBlock Grid.Column="2" x:Name="StatusText" Text="{Binding Status}" Margin="12,0,4,0" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Visibility="Collapsed"/>
                                            </Grid>

                                            <HierarchicalDataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                    <Setter TargetName="FolderIcon" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFile}" Value="True">
                                                    <Setter TargetName="FileIcon" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="StatusText" Property="Visibility" Value="Visible"/>
                                                </DataTrigger>

                                                <!-- Colors and ToolTips for status -->
                                                <DataTrigger Binding="{Binding Status}" Value="M">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#D29A2E"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Modified"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="A">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#57B05C"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Added"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="D">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#E05B5B"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Deleted"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="??">
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="Gray"/>
                                                    <Setter TargetName="RowGrid" Property="ToolTip" Value="Untracked"/>
                                                </DataTrigger>
                                            </HierarchicalDataTemplate.Triggers>
                                        </HierarchicalDataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </Expander>

                            <!-- Outgoing commits list -->
                            <Expander Style="{StaticResource VsExpanderStyle}" IsExpanded="True" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">
                                <Expander.Header>
                                    <TextBlock Text="{Binding AheadCount, StringFormat='Outgoing commits ({0})'}" 
                                               FontFamily="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontFamilyKey}}"
                                               FontSize="{DynamicResource {x:Static vsshell:VsFonts.CaptionFontSizeKey}}"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                </Expander.Header>
                                <ListView Name="OutgoingListBox" ItemsSource="{Binding Outgoing}" MouseDoubleClick="OutgoingListBox_MouseDoubleClick"
                                          Style="{x:Null}"
                                          Background="Transparent" BorderThickness="0" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListViewItem">
                                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderThickness="0" Padding="4,2" SnapsToDevicePixels="True">
                                                            <GridViewRowPresenter Content="{TemplateBinding Content}" Columns="{TemplateBinding GridView.ColumnCollection}"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemActiveBrushKey}}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemActiveTextBrushKey}}"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsSelected" Value="True"/>
                                                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemInactiveBrushKey}}"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource {x:Static platformUI:TreeViewColors.SelectedItemInactiveTextBrushKey}}"/>
                                                            </MultiTrigger>
                                                            <MultiTrigger>
                                                                 <MultiTrigger.Conditions>
                                                                     <Condition Property="IsMouseOver" Value="True"/>
                                                                     <Condition Property="IsSelected" Value="False"/>
                                                                 </MultiTrigger.Conditions>
                                                                 <Setter TargetName="Bd" Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                                             </MultiTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.View>
                                        <GridView ColumnHeaderContainerStyle="{StaticResource VsGridViewColumnHeaderStyle}">
                                            <GridViewColumn Header="Message" Width="380">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Subject}" Style="{StaticResource PrimaryTextBlockStyle}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Author" Width="100">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Author}" Style="{StaticResource SubduedTextBlockStyle}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="Date" Width="100">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Date}" Style="{StaticResource SubduedTextBlockStyle}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="ID" Width="80">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ShortSha}" Style="{StaticResource SubduedTextBlockStyle}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
 
                    <!-- Row 2: Action Buttons footer -->
                    <Border Grid.Row="2" BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ActiveBorderKey}}" BorderThickness="0,1,0,0" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Grid Margin="0,0,6,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Command="{Binding OpenCommand}" CommandParameter="{Binding PreferredOpenAction}" Width="75" Height="26" FontSize="12">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <ContentControl Content="{Binding PreferredOpenAction}" Margin="0,0,4,0" VerticalAlignment="Center">
                                                <ContentControl.Style>
                                                    <Style TargetType="ContentControl">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding PreferredOpenAction}" Value="CurrentWindow">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate>
                                                                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Solution}" Width="14" Height="14"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PreferredOpenAction}" Value="NewVSWindow">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate>
                                                                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.VisualStudio}" Width="14" Height="14"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PreferredOpenAction}" Value="DoNotOpen">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate>
                                                                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.VisualStudio}" Width="14" Height="14"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding PreferredOpenAction}" Value="Explorer">
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate>
                                                                            <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.OpenFolder}" Width="14" Height="14"/>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ContentControl.Style>
                                            </ContentControl>
                                            <TextBlock Text="Open" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1" Click="ButtonOpen_Click" Width="12" Height="26" Padding="0">
                                        <Path Data="M1,2.5 L4,5.5 L7,2.5" Stroke="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" StrokeThickness="1" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Open in Current Window" Command="{Binding OpenCommand}" CommandParameter="CurrentWindow">
                                                    <MenuItem.Icon>
                                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.Solution}" Width="16" Height="16"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="Open in New VS Window" Command="{Binding OpenCommand}" CommandParameter="NewVSWindow">
                                                    <MenuItem.Icon>
                                                        <imaging:CrispImage Moniker="{x:Static catalog:KnownMonikers.VisualStudio}" Width="16" Height="16"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </StackPanel>
 
                            <!-- Remove button -->
                            <Button Grid.Column="2" Content="Remove" Command="{Binding RemoveCommand}" Width="90" Height="26" FontSize="12"/>
                        </Grid>
                    </Border>
                </Grid>
 
                <!-- LoadingWorktrees state panel -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="LoadingWorktrees">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Loading worktrees..." FontSize="12" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <ProgressBar Width="150" Height="4" IsIndeterminate="True" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.AccentBorderKey}}"/>
                    </StackPanel>
                </Grid>

                <!-- Empty Selection state -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentState}" Value="NoSelection">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <TextBlock Text="Select a worktree to manage" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}" FontSize="13"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
